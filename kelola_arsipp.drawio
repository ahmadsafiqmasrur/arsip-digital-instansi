<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Kelola Arsip (CRUD + Join)" id="activity-kelola-arsip">
    <mxGraphModel dx="1683" dy="1009" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1"
                  page="1" pageScale="1" pageWidth="827" pageHeight="1169"
                  math="0" shadow="0">
      <root>
        <!-- Root cells -->
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Swimlane container (group) -->
        <mxCell id="swimlane_container" value="" style="group" vertex="1" connectable="0"
                parent="1">
          <mxGeometry x="80" y="40" width="600" height="820" as="geometry"/>
        </mxCell>
        <!-- Actor swimlane (Koordinator & Petugas) -->
        <mxCell id="lane_admin" value="Koordinator &amp; Petugas"
                style="swimlane;whiteSpace=wrap;html=1;startSize=40;" vertex="1"
                parent="swimlane_container">
          <mxGeometry width="300" height="820" as="geometry"/>
        </mxCell>
        <!-- System swimlane -->
        <mxCell id="lane_sistem" value="Sistem"
                style="swimlane;whiteSpace=wrap;html=1;startSize=40;" vertex="1"
                parent="swimlane_container">
          <mxGeometry x="300" width="300" height="820" as="geometry"/>
        </mxCell>
        <!-- START node (actor) -->
        <mxCell id="start_node" value="" style="ellipse;html=1;shape=startState;
                fillColor=#000000;strokeColor=#ff0000;" vertex="1"
                parent="lane_admin">
          <mxGeometry x="135" y="60" width="30" height="30" as="geometry"/>
        </mxCell>
        <!-- TEXT “Mulai” -->
        <mxCell id="txt_mulai" value="Mulai" style="text;html=1;align=center;
                verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1"
                parent="lane_admin">
          <mxGeometry x="125" y="90" width="50" height="30" as="geometry"/>
        </mxCell>
        <!-- MENU “Kelola Arsip” -->
        <mxCell id="select_menu" value="Memilih Menu&#xa;Kelola Arsip"
                style="rounded=0;whiteSpace=wrap;html=1;" vertex="1"
                parent="lane_admin">
          <mxGeometry x="90" y="140" width="120" height="60" as="geometry"/>
        </mxCell>
        <!-- EDGE start → menu -->
        <mxCell id="edge_start_menu" edge="1" source="start_node"
                target="select_menu"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;strokeColor=#ff0000;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- INPUT DATA (actor) -->
        <mxCell id="input_data" value="Menginput Data"
                style="rounded=0;whiteSpace=wrap;html=1;" vertex="1"
                parent="lane_admin">
          <mxGeometry x="90" y="280" width="120" height="60" as="geometry"/>
        </mxCell>
        <!-- EDGE menu → input -->
        <mxCell id="edge_menu_input" edge="1" source="select_menu"
                target="input_data"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- BUTTON “Simpan” (actor) -->
        <mxCell id="click_save" value="Klik Tombol Simpan"
                style="rounded=0;whiteSpace=wrap;html=1;" vertex="1"
                parent="lane_admin">
          <mxGeometry x="90" y="420" width="120" height="60" as="geometry"/>
        </mxCell>
        <!-- EDGE input → save -->
        <mxCell id="edge_input_save" edge="1" source="input_data"
                target="click_save"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- SHOW FORM (system) -->
        <mxCell id="show_form" value="Menampilkan Form&#xa;dan Daftar Arsip"
                style="rounded=0;whiteSpace=wrap;html=1;" vertex="1"
                parent="lane_sistem">
          <mxGeometry x="90" y="140" width="120" height="60" as="geometry"/>
        </mxCell>
        <!-- EDGE save → show_form -->
        <mxCell id="edge_save_form" edge="1" source="click_save"
                target="show_form"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- VALIDATE DATA (system) -->
        <mxCell id="validate_data" value="Validasi Kelengkapan&#xa;Data"
                style="rounded=0;whiteSpace=wrap;html=1;" vertex="1"
                parent="lane_sistem">
          <mxGeometry x="90" y="420" width="120" height="60" as="geometry"/>
        </mxCell>
        <!-- EDGE form → validate -->
        <mxCell id="edge_form_validate" edge="1" source="show_form"
                target="validate_data"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- DECISION “Proses Valid?” -->
        <mxCell id="check_process" value="Proses Valid?"
                style="rhombus;whiteSpace=wrap;html=1;" vertex="1"
                parent="lane_sistem">
          <mxGeometry x="100" y="520" width="100" height="100" as="geometry"/>
        </mxCell>
        <!-- EDGE validate → decision -->
        <mxCell id="edge_validate_check" edge="1" source="validate_data"
                target="check_process"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- DECISION “Aksi (Tambah | Edit | Hapus)” -->
        <mxCell id="action_choice" value="Aksi (Tambah | Edit | Hapus)"
                style="rhombus;whiteSpace=wrap;html=1;strokeColor=#000000;"
                vertex="1" parent="swimlane_container">
          <mxGeometry x="250" y="720" width="120" height="80" as="geometry"/>
        </mxCell>
        <!-- EDGE decision → aksi -->
        <mxCell id="edge_check_to_choice" edge="1" source="check_process"
                target="action_choice"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- ACTION “Tambah” -->
        <mxCell id="add_node" value="Tambah Data"
                style="rounded=0;whiteSpace=wrap;html=1;" vertex="1"
                parent="swimlane_container">
          <mxGeometry x="100" y="840" width="120" height="60" as="geometry"/>
        </mxCell>
        <!-- ACTION “Edit” -->
        <mxCell id="edit_node" value="Edit Data"
                style="rounded=0;whiteSpace=wrap;html=1;" vertex="1"
                parent="swimlane_container">
          <mxGeometry x="250" y="840" width="120" height="60" as="geometry"/>
        </mxCell>
        <!-- ACTION “Hapus” -->
        <mxCell id="delete_node" value="Hapus Data"
                style="rounded=0;whiteSpace=wrap;html=1;" vertex="1"
                parent="swimlane_container">
          <mxGeometry x="400" y="840" width="120" height="60" as="geometry"/>
        </mxCell>
        <!-- EDGE decision → tambah -->
        <mxCell id="edge_choice_to_add" edge="1" source="action_choice"
                target="add_node"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- EDGE decision → edit -->
        <mxCell id="edge_choice_to_edit" edge="1" source="action_choice"
                target="edit_node"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- EDGE decision → hapus -->
        <mxCell id="edge_choice_to_delete" edge="1" source="action_choice"
                target="delete_node"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- JOIN node (ellipse) -->
        <mxCell id="join_node"
                style="ellipse;whiteSpace=wrap;html=1;strokeColor=#000000;"
                vertex="1" parent="swimlane_container">
          <mxGeometry x="300" y="960" width="30" height="30" as="geometry"/>
        </mxCell>
        <!-- Edge Tambah → Join -->
        <mxCell id="edge_add_to_join" edge="1" source="add_node"
                target="join_node"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Edge Edit → Join -->
        <mxCell id="edge_edit_to_join" edge="1" source="edit_node"
                target="join_node"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Edge Hapus → Join -->
        <mxCell id="edge_delete_to_join" edge="1" source="delete_node"
                target="join_node"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- END node (system) -->
        <mxCell id="end_node" value="" style="ellipse;html=1;shape=endState;
                fillColor=#000000;strokeColor=#ff0000;" vertex="1"
                parent="lane_sistem">
          <mxGeometry x="135" y="1080" width="30" height="30" as="geometry"/>
        </mxCell>
        <!-- TEXT “Selesai” -->
        <mxCell id="txt_selesai" value="Selesai"
                style="text;html=1;align=center;verticalAlign=middle;
                       strokeColor=none;fillColor=none;" vertex="1"
                parent="lane_sistem">
          <mxGeometry x="120" y="1110" width="60" height="30" as="geometry"/>
        </mxCell>
        <!-- Edge Join → End -->
        <mxCell id="edge_join_to_end" edge="1" source="join_node"
                target="end_node"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;
                       jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
